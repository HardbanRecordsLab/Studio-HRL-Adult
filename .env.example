# App
NEXT_PUBLIC_SITE_URL=https://studio-adult.hardbanrecordslab.online
NEXT_PUBLIC_API_URL=https://studio-adult.hardbanrecordslab.online/api

# JWT Authentication (REQUIRED - generate a strong random string)
JWT_SECRET=your-strong-random-secret-here-min-32-chars
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-strong-admin-password-here

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
POSTGRES_PASSWORD=your-db-password
POSTGRES_USER=postgres
POSTGRES_HOST=db.host.supabase.co
POSTGRES_URL=postgres://user:password@host:6543/database?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database?sslmode=require

# Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://api-key:api-secret@cloud-name

# Email (SMTP)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@example.com
EMAIL_SERVER_PASSWORD=your-email-password
EMAIL_FROM=your-email@example.com

# Contact
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
